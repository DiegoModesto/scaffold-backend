{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "base-scaffold",
    "Audience": "base-scaffold-clients",
    "ExpirationInMinutes": 60,
    "RequireHttpsMetadata": true
  },
  "RabbitMq": {
    "Host": "",
    "Port": 5672,
    "User": "",
    "Password": "",
    "VirtualHost": "/",
    "ExchangeName": "sample.exchange",
    "QueueName": "sample.queue",
    "RoutingKey": "sample.key"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
