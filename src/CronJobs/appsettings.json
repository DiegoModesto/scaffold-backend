{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=base_scaffold;Username=postgres;Password=postgres;"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_A_256_BIT_SECRET_REPLACE_ME_NOW",
    "Issuer": "base-scaffold",
    "Audience": "base-scaffold-clients",
    "ExpirationInMinutes": 60
  },
  "CronJobs": {
    "SampleSchedule": "*/5 * * * *"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "ServerUrl": "http://seq:5341" } }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
